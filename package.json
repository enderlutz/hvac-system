{
  "name": "hvac-system",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && uvicorn main:app --reload --port 8000",
    "frontend": "cd frontend && npx next dev -p 3000"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
